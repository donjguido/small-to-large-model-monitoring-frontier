---
import type { Entry } from '../data';
interface Props { entry: Entry }
const { entry } = Astro.props;

function formatAuthors(authors: string[]): string {
  if (authors.length <= 3) return authors.join(', ');
  return authors.slice(0, 2).join(', ') + ', … ' + authors[authors.length - 1];
}
---
<article class="entry" id={`entry-${entry.id}`}>
  <div class="head">
    <div class="title-line">
      {entry.is_foundational && <span class="star" title="Foundational reference">★</span>}
      {entry.url
        ? <a href={entry.url} rel="noopener">{entry.title}</a>
        : <span>{entry.title}</span>
      }
      <a class="anchor" href={`#entry-${entry.id}`}>¶</a>
    </div>
  </div>
  <div class="meta">
    {formatAuthors(entry.authors)} ({entry.year}) · {entry.venue}
    {entry.arxiv_id && <> · <span class="arxiv">arXiv:{entry.arxiv_id}</span></>}
  </div>
  <div class="annotation" set:html={entry.annotation.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>').replace(/\*(.+?)\*/g, '<em>$1</em>')} />
  <div class="tags">
    {entry.needs_verification && <span class="tag needs-verification">needs verification</span>}
    {entry.tags.map((t) => <span class={`tag ${t}`}>{t}</span>)}
  </div>
</article>
